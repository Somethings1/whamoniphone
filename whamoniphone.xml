//
//  WhamAnalyzer.swift
//  WhamApp
//

import Foundation
import AVFoundation
import CoreML
import UIKit

@MainActor
class WhamAnalyzer: ObservableObject {
    @Published var progress: Double = 0
    @Published var isProcessing = false
    @Published var statusMessage: String = ""
    @Published var debugImage: UIImage?
    
    init() {}

    func analyze(videoURL: URL, jsonURL: URL) async {
        self.isProcessing = true
        self.progress = 0
        self.statusMessage = "Đang chuẩn bị dữ liệu..."
        
        do {
            // Đẩy TOÀN BỘ việc nặng ra Background Thread để chống treo máy
            try await Task.detached(priority: .userInitiated) {
                let gyroData = try self.loadGyroData(from: jsonURL)
                let asset = AVURLAsset(url: videoURL)
                let reader = try AVAssetReader(asset: asset)
                let tracks = try await asset.loadTracks(withMediaType: .video)
                guard let track = tracks.first else { return }
                let videoSize = try await track.load(.naturalSize)

                let output = AVAssetReaderTrackOutput(track: track, outputSettings: [
                    kCVPixelBufferPixelFormatTypeKey as String: kCVPixelFormatType_32BGRA
                ])
                reader.add(output)
                reader.startReading()
                
                var allFeatures: [MLMultiArray] = []
                var frameIdx = 0

                await MainActor.run { self.statusMessage = "Đang nạp AI Thị giác..." }
                var poseDetector: PoseDetector? = PoseDetector()
                var fastViT: _FastViT? = try _FastViT(configuration: MLModelConfiguration())
                
                await MainActor.run { self.statusMessage = "Đang trích xuất (Stage 1/2)..." }
                
                // ==========================================
                // VÒNG LẶP STAGE 1: BỌC AUTORELEASEPOOL CHỐNG RÒ RỈ RAM
                // ==========================================
                while reader.status == .reading {
                    guard let buffer = output.copyNextSampleBuffer() else { break }
                    
                    try autoreleasepool {
                        if let pix = CMSampleBufferGetImageBuffer(buffer) {
                            if let person = poseDetector?.detect(pixelBuffer: pix).first,
                               let cropped = self.cropPixelBuffer(pix, to: person.box) {
                                
                                let vitInput = _FastViTInput(image_input: cropped)
                                if let vitOutput = try fastViT?.prediction(input: vitInput) {
                                    let reshapedFeat = try self.reshapeTo1x1x1024(vitOutput.features_1024)
                                    allFeatures.append(reshapedFeat)
                                }
                            } else {
                                allFeatures.append(try self.zeros([1, 1, 1024]))
                            }
                        }
                    }
                    
                    frameIdx += 1
                    let currentProgress = (Double(frameIdx) / Double(gyroData.count)) * 0.5
                    await MainActor.run { self.progress = currentProgress }
                }
                
                // ==========================================
                // ĐẠI PHÁP "BUỒNG KHÔNG KHÍ" (AIRLOCK)
                // ==========================================
                await MainActor.run { self.statusMessage = "Đang dọn dẹp RAM..." }
                poseDetector = nil
                fastViT = nil
                
                // Ép thời gian chết để iOS dọn RAM thực sự
                try await Task.sleep(nanoseconds: 3_000_000_000)
                
                // ==========================================
                // VÒNG LẶP STAGE 2: WHAM_INT8_SAFE INFERENCE
                // ==========================================
                await MainActor.run { self.statusMessage = "Đang nạp AI WHAM_INT8_SAFE RNN..." }
                
                let whamConfig = MLModelConfiguration()
                whamConfig.computeUnits = .cpuOnly

                // Khai báo biến Optional và nạp Model
                var whamRNN: WHAM_INT8_SAFE? = nil
                do {
                    whamRNN = try await WHAM_INT8_SAFE.load(configuration: whamConfig)
                    print("🎉 Load model thành công! RAM iPhone 11 vẫn sống!")
                } catch {
                    print("❌ Lỗi khởi tạo Model: \(error)")
                    await MainActor.run { self.statusMessage = "Lỗi nạp Model!" }
                    return // Phanh gấp
                }

                // Chốt chặn an toàn: Bóc vỏ Optional để dùng thẳng
                guard let whamModel = whamRNN else {
                    print("❌ Lỗi: Model bị nil bất thường.")
                    return
                }

                await MainActor.run { self.statusMessage = "Đang nội suy 3D (Stage 2/2)..." }
                var whamResults: [[String: Any]] = []
                let totalFrames = allFeatures.count
                
                // TỐI ƯU HÓA CỰC ĐỘ: KHAI BÁO CÁC MẢNG HẰNG SỐ Ở NGOÀI VÒNG LẶP
                // Đừng bao giờ nhét cái này vào trong for-loop, nó sẽ gây tràn RAM!
                let init_kp = try self.zeros([1, 1, 88])
                let init_smpl = try self.zeros([1, 1, 24, 6])
                let mask = try self.ones([1, 81, 17])
                let init_root = try self.zeros([1, 1, 6])
                let dummy_x = try self.zeros([1, 81, 37])
                let dummy_bbox = try self.zeros([1, 81, 3])
                let cam_angvel = try self.zeros([1, 81, 6])
                
                let cam_intrinsics = try self.zeros([1, 1, 3, 3])
                cam_intrinsics[[0, 0, 0, 0] as [NSNumber]] = 1.0
                cam_intrinsics[[0, 0, 1, 1] as [NSNumber]] = 1.0
                cam_intrinsics[[0, 0, 2, 2] as [NSNumber]] = 1.0
                
                let res = try self.zeros([1, 2])
                res[[0, 0] as [NSNumber]] = NSNumber(value: Float(videoSize.width))
                res[[0, 1] as [NSNumber]] = NSNumber(value: Float(videoSize.height))

                // VÒNG LẶP CHÍNH
                for i in 0..<totalFrames {
                    try autoreleasepool {
                        let win = (i..<i+81).map { min($0, totalFrames - 1) }
                        
                        // Chỉ có phần Features là thay đổi, nên mới để trong này
                        let stackedFeatures = try self.stackArrays(win.map { allFeatures[$0] })
                        
                        let input = WHAM_INT8_SAFEInput(
                            in_0: dummy_x, in_1: init_kp, in_2: init_smpl, in_3: stackedFeatures,
                            in_4: mask, in_5: init_root, in_6: cam_angvel, in_7: cam_intrinsics,
                            in_8: dummy_bbox, in_9: res
                        )
                        
                        // Gọi model prediction mà KHÔNG DÙNG DẤU CHẤM HỎI NỮA
                        let prediction = try whamModel.prediction(input: input)
                        
                        // Demo lưu dữ liệu (Ông sẽ parse prediction.pose_6d thực tế ở đây sau)
                        whamResults.append(["pose_6d": "Success - Got Data!"])
                    }
                    
                    let currentProgress = 0.5 + (Double(i) / Double(totalFrames)) * 0.5
                    await MainActor.run { self.progress = currentProgress }
                }
                
                let finalData = try JSONSerialization.data(withJSONObject: whamResults)
                try finalData.write(to: jsonURL)
                
                // Giải phóng model sau khi chạy xong
                whamRNN = nil
                
            }.value // Đợi luồng Background chạy xong
            
            self.statusMessage = "✅ PHÂN TÍCH THÀNH CÔNG!"
            self.isProcessing = false
            
        } catch {
            print("❌ Analysis Failed: \(error)")
            self.statusMessage = "❌ Lỗi: \(error.localizedDescription)"
            self.isProcessing = false
        }
    }

    // --- HELPER FUNCTIONS ---
    
    nonisolated private func stackArrays(_ arrays: [MLMultiArray]) throws -> MLMultiArray {
        return try MLMultiArray(concatenating: arrays, axis: 1, dataType: .float32)
    }
    
    nonisolated private func reshapeTo1x1x1024(_ arr: MLMultiArray) throws -> MLMultiArray {
        let newArr = try MLMultiArray(shape: [1, 1, 1024], dataType: .float32)
        for i in 0..<1024 { newArr[[0, 0, i] as [NSNumber]] = arr[[0, i] as [NSNumber]] }
        return newArr
    }

    nonisolated private func zeros(_ shape: [NSNumber]) throws -> MLMultiArray {
        return try MLMultiArray(shape: shape, dataType: .float32)
    }

    nonisolated private func ones(_ shape: [NSNumber]) throws -> MLMultiArray {
        let arr = try MLMultiArray(shape: shape, dataType: .float32)
        for i in 0..<arr.count { arr[i] = 1.0 }
        return arr
    }

    nonisolated private func cropPixelBuffer(_ buffer: CVPixelBuffer, to rect: CGRect) -> CVPixelBuffer? {
        let ciImage = CIImage(cvPixelBuffer: buffer).cropped(to: rect)
        let moveOrigin = CGAffineTransform(translationX: -rect.origin.x, y: -rect.origin.y)
        let scaleX = 256.0 / rect.width
        let scaleY = 256.0 / rect.height
        let scale = CGAffineTransform(scaleX: scaleX, y: scaleY)
        let finalTransform = moveOrigin.concatenating(scale)
        let resized = ciImage.transformed(by: finalTransform)
        
        var newBuffer: CVPixelBuffer?
        CVPixelBufferCreate(nil, 256, 256, kCVPixelFormatType_32BGRA, nil, &newBuffer)
        if let nb = newBuffer { CIContext().render(resized, to: nb) }
        return newBuffer
    }
    
    nonisolated private func loadGyroData(from url: URL) throws -> [[String: Any]] {
        let data = try Data(contentsOf: url)
        return try JSONSerialization.jsonObject(with: data) as? [[String: Any]] ?? []
    }
}
