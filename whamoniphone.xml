                            Text("BẮT ĐẦU PHÂN TÍCH WHAM")
                                .fontWeight(.bold)
                        }
                        .frame(maxWidth: .infinity)
                        .padding()
                        .background(video.hasGyro ? Color.blue : Color.gray)
                        .foregroundColor(.white)
                        .cornerRadius(12)
                    }
                    .disabled(!video.hasGyro)
                    .padding()
                }
                
                // Hiện thông báo thành công hoặc thất bại sau khi chạy xong
                if !analyzer.statusMessage.isEmpty && !analyzer.isProcessing {
                    Text(analyzer.statusMessage)
