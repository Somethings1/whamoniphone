<file path="remote_build.sh">
#!/bin/bash

# 1. Cấu hình các thông số
PROJECT_NAME="WhamApp.xcodeproj"
SCHEME_NAME="WhamApp"
BUNDLE_ID="com.yourname.WhamApp" # Thay bằng Bundle ID của bạn

# 2. Build dự án ra file .app (Sử dụng kiến trúc ARM64 cho iPhone 11 PM)
xcodebuild build \
    -project $PROJECT_NAME \
    -scheme $SCHEME_NAME \
    -destination 'generic/platform=iOS' \
    -configuration Debug \
    -derivedDataPath build

# 3. Tìm đường dẫn file .app vừa build xong
APP_PATH=$(find build -name "*.app" | head -n 1)

# 4. Gỡ app cũ, cài app mới và TỰ ĐỘNG MỞ (Refresh)
# -r: Gỡ cài đặt trước khi cài
# -n: Chạy app ngay sau khi cài xong
/usr/local/bin/ios-deploy --bundle "$APP_PATH" --justlaunch --debug
