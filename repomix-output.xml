import Foundation

// Dữ liệu Gyro thô từ CoreMotion
struct GyroFrame: Codable {
    let t: Double  // Timestamp để đồng bộ với video
    let x: Double, y: Double, z: Double // Vận tốc góc (Angular Velocity)
}

// Model quản lý video trong thư viện
struct VideoModel: Identifiable {
    let id: UUID
    let url: URL
    var isAnalyzed: Bool = false // Đánh dấu nếu đã chạy WHAM xong [cite: 581]
}
