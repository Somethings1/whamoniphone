import SwiftUI

// 1. Giao diện chính với Camera
struct MainCameraView: View {
    @StateObject var manager = WhamCaptureManager()
    @State private var showLibrary = false

    var body: some View {
        ZStack {
            CameraPreview(session: manager.session).ignoresSafeArea()

            VStack {
                Spacer()
                HStack {
                    // Nút mở Thư viện bên trái
                    Button(action: { showLibrary = true }) {
                        Group {
                            if let thumb = manager.lastThumbnail {
                                Image(uiImage: thumb).resizable().aspectRatio(contentMode: .fill)
                            } else { Color.gray }
                        }
                        .frame(width: 60, height: 60).cornerRadius(10)
                        .overlay(RoundedRectangle(cornerRadius: 10).stroke(Color.white, lineWidth: 2))
                    }
                    Spacer()
                    // Nút Quay chính giữa
                    Button(action: manager.toggleRecording) {
                        Circle().fill(manager.isRecording ? .red : .white)
                            .frame(width: 70, height: 70)
                            .overlay(Circle().stroke(.white, lineWidth: 3).padding(-5))
                    }
                    Spacer()
                    Color.clear.frame(width: 60)
                }.padding(30)
            }
        }.sheet(isPresented: $showLibrary) { VideoLibraryView() }
    }
}

// 2. TabView hiển thị kết quả phân tích
struct VideoDetailView: View {
    let video: VideoModel
    @State private var tab = 0

    var body: some View {
        VStack {
            if video.isAnalyzed {
                TabView(selection: $tab) {
                    // Tab 1: Stickman (Vẽ 2D lên video gốc) [cite: 152]
                    Text("Video Overlay (Stickman)").tag(0)
                    // Tab 2: SceneKit (3D World View không trượt chân) [cite: 12, 199]
                    Text("SceneKit 3D World View").tag(1)
                }
                .tabViewStyle(.page)
            } else {
                Button("Bắt đầu phân tích WHAM") { /* Gọi logic AI ở đây */ }
                    .buttonStyle(.borderedProminent)
            }
        }
        .navigationTitle(tab == 0 ? "2D Preview" : "3D World Space")
    }
}
